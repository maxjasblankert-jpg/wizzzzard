# Copy this file to .env — project defaults below match wizard-f356d.
# Replace YOUR_API_KEY and YOUR_APP_ID (or copy from public/firebase-config.js).
#
# Local workflow:
#   1. cp .env.example .env   (or copy manually on Windows)
#   2. Edit .env with your keys
#   3. npm run sync:firebase  → writes public/firebase-config.js for npm start
#   4. npm run build:vercel   → uses .env when building dist locally
#
# Vercel: set the same FIREBASE_* variables in the project Environment Variables
# (build does not read .env on Vercel — use the dashboard or `vercel env`).

FIREBASE_API_KEY=YOUR_API_KEY
FIREBASE_AUTH_DOMAIN=wizard-f356d.firebaseapp.com
FIREBASE_PROJECT_ID=wizard-f356d
FIREBASE_STORAGE_BUCKET=wizard-f356d.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=736283800688
FIREBASE_APP_ID=YOUR_APP_ID

# Optional — local WebSocket server (npm start)
PORT=3001

# Neural bot service (Champion bots in Standard mode)
# Local: http://127.0.0.1:8001 after `cd neural-bot && pip install -r requirements-bot.txt && uvicorn bot_service:app --port 8001`
# Production: your Render/Railway URL
BOT_SERVICE_URL=http://127.0.0.1:8001
